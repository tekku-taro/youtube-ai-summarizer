{
  "manifest_version": 3,
  "name": "YouTube AI Summary Extension",
  "version": "0.0.1",
  "description": "YouTube transcript and AI summary helper",
  "permissions": ["storage", "scripting"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_title": "Open AI Summary",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["src/main.tsx"]
    }
  ]
}