{
  "manifest_version": 3,
  "name": "YouTube AI Summary Extension",
  "version": "0.0.1",
  "description": "YouTube transcript and AI summary helper",
  "permissions": ["storage", "scripting"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_title": "YouTube AI Summary",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/watch*"
      ],
      "js": ["src/main.tsx"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.ico",
    "32": "icons/icon32.ico",
    "48": "icons/icon48.ico",
    "128": "icons/icon128.ico"
  }  
}